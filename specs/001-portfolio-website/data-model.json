{
  "$id": "https://example.com/schemas/portfolio-data-model.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Interactive Portfolio Website Data Model",
  "type": "object",
  "required": ["profile", "experience", "projects", "skills", "education", "awards", "languages", "themes", "contact"],
  "properties": {
    "profile": {
      "type": "object",
      "required": ["name", "title", "contact"],
      "properties": {
        "name": {"type": "string"},
        "title": {"type": "string"},
        "location": {"type": "string"},
        "contact": {"type": "object"},
        "about": {"type": "string"},
        "photo": {"type": "string"},
        "objective": {"type": "string"}
      }
    },
    "experience": {"type": "array"},
    "projects": {"type": "array"},
    "skills": {"type": "object"},
    "education": {"type": "array"},
    "awards": {"type": "array"},
    "languages": {"type": "array"},
    "themes": {"type": "object"},
    "contact": {"type": "object"}
  }
}
